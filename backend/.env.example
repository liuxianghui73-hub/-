# OpenAI API 配置（必填）
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-chat
OPENAI_TIMEOUT=60

# 数据库配置
MONGODB_URI=mongodb://mongodb:27017
DATABASE_NAME=isa_sales_agent

# 向量数据库配置（ChromaDB）
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=sales_knowledge

# Redis 配置
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# 应用配置
APP_ENV=production
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000

# CORS 配置
CORS_ORIGINS=http://localhost:3000,http://frontend:3000

# API 鉴权（前端调用后端 API 的密钥）
API_SECRET_KEY=your-secret-key-change-in-production

# 速率限制配置
RATE_LIMIT_PER_MINUTE=10

